/-- Placeholder for a width invariant on monomials (hard/algorithmic). -/
constant width : R m n k → ℕ

/-- (Hard) Sturmfels-style characterization: monomial ∈ init(detIdeal (r+1)) ↔ width ≥ r+1. -/
theorem mem_init_rankIdeal_iff_width
    (r : ℕ) (M : R m n k) :
    M ∈ initIdeal (m := m) (n := n) (k := k) ord (rankIdeal (m := m) (n := n) (k := k) r)
      ↔ width (m := m) (n := n) (k := k) ord M ≥ r+1 := by
