import Mathlib

open scoped BigOperators

namespace Determinantal

/-! ### 0. Base setup -/

variable {k : Type*} [CommRing k]

abbrev R (m n : ℕ) (k : Type*) [CommRing k] := MvPolynomial (Fin m × Fin n) k

/-- The generic m×n matrix with entries X_{ij} as variables in `MvPolynomial`. -/
noncomputable def genericMatrix (m n : ℕ) (k : Type*) [CommRing k] :
    Matrix (Fin m) (Fin n) (R m n k) :=
  fun i j => MvPolynomial.X (i, j)

@[simp] lemma genericMatrix_apply {m n : ℕ} (i : Fin m) (j : Fin n) :
    genericMatrix (m := m) (n := n) k i j = (MvPolynomial.X (i, j) : R m n k) := rfl

/-! ### 1. Indices for minors -/

/--
Index data for a t×t minor:
choose t distinct rows and t distinct columns via embeddings.
-/
structure MinorIndex (m n t : ℕ) where
  row : Fin t ↪o Fin m
  col : Fin t ↪o Fin n

attribute [simp] MinorIndex.row MinorIndex.col

/-- The t×t minor of the generic matrix corresponding to `I`. -/
noncomputable def minor {m n : ℕ} {t : ℕ} (I : MinorIndex m n t) : R m n k :=
  Matrix.det <|
    Matrix.submatrix (genericMatrix (m := m) (n := n) k) I.row I.col

/-- The set of all t×t minors (as polynomials). -/
def minorSet {m n : ℕ} (t : ℕ) : Set (R m n k) :=
  { f | ∃ I : MinorIndex m n t, f = minor (m := m) (n := n) (k := k) I }

@[simp] lemma mem_minorSet_iff {m n : ℕ} {t : ℕ} {f : R m n k} :
    f ∈ minorSet (m := m) (n := n) (k := k) t
      ↔ ∃ I : MinorIndex m n t, f = minor (m := m) (n := n) (k := k) I := Iff.rfl

lemma minor_mem_minorSet {m n : ℕ} {t : ℕ} (I : MinorIndex m n t) :
    minor (m := m) (n := n) (k := k) I ∈ minorSet (m := m) (n := n) (k := k) t :=
  ⟨I, rfl⟩

/-! ### 2. Determinantal ideals -/

/-- The determinantal ideal generated by all t×t minors. -/
def detIdeal {m n : ℕ} (t : ℕ) : Ideal (R m n k) :=
  Ideal.span (minorSet (m := m) (n := n) (k := k) t)

lemma minor_mem_detIdeal {m n : ℕ} {t : ℕ} (I : MinorIndex m n t) :
    minor (m := m) (n := n) (k := k) I ∈ detIdeal (m := m) (n := n) (k := k) t := by
  -- immediate from `Ideal.subset_span`
  exact Ideal.subset_span (minor_mem_minorSet (m := m) (n := n) (k := k) I)

lemma detIdeal_mono {m n : ℕ} {t₁ t₂ : ℕ}
  (h : minorSet (m := m) (n := n) (k := k) t₁ ⊆ minorSet t₂) :
    detIdeal (m := m) (n := n) (k := k) t₁ ≤ detIdeal t₂ := by
  -- span is monotone
  exact Ideal.span_mono h

/-- The rank-≤r determinantal ideal is generated by (r+1)-minors. -/
abbrev rankIdeal {m n : ℕ} (r : ℕ) : Ideal (R m n k) := detIdeal (m := m) (n := n) (k := k) (r+1)

/-! ### 3. Anti-diagonal monomials (expected leading terms) -/

/--
Exponent vector of the "anti-diagonal" monomial of a t×t minor.

Typical expectation under an anti-diagonal (or suitable diagonal) term order:
  LM(minor I) = monomial (antiDiagExp I) 1
-/
noncomputable def antiDiagExp {m n : ℕ} {t : ℕ} (I : MinorIndex m n t) : (Fin m × Fin n) →₀ ℕ :=
  ∑ i : Fin t, Finsupp.single (I.row i, I.col (Fin.rev i)) 1

/-- The corresponding anti-diagonal monomial as a polynomial. -/
noncomputable def antiDiagMonom {m n : ℕ} {t : ℕ} (I : MinorIndex m n t) : R m n k :=
  MvPolynomial.monomial (antiDiagExp (m := m) (n := n) (t := t) I) (1 : k)

lemma antiDiagMonom_ne_zero {m n : ℕ} {t : ℕ} (I : MinorIndex m n t) :
    antiDiagMonom (m := m) (n := n) (k := k) I ≠ 0 := by
  -- This is usually true because coefficient is 1; keep as a small lemma placeholder.
  -- You may prove it using `MvPolynomial.monomial_eq_zero` (depending on the exact lemma names).
  sorry

