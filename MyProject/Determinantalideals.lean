/-! ### 5. Small “obvious” helper lemmas you can extend -/

section Helpers

/-- A minor is in the rank ideal iff its size matches (r+1). -/
lemma minor_mem_rankIdeal {r t : ℕ} (h : t = r+1) (I : MinorIndex m n t) :
    minor (m := m) (n := n) (k := k) I ∈ rankIdeal (m := m) (n := n) (k := k) r := by
  subst h
  simpa [rankIdeal] using minor_mem_detIdeal (m := m) (n := n) (k := k) I

/--
You will often need "closure under multiplication" facts:
if `f ∈ detIdeal t` then `g*f ∈ detIdeal t`.
-/
lemma mul_mem_detIdeal_left {t : ℕ} (g : R m n k) {f : R m n k}
    (hf : f ∈ detIdeal (m := m) (n := n) (k := k) t) :
    g * f ∈ detIdeal (m := m) (n := n) (k := k) t := by
  exact (detIdeal (m := m) (n := n) (k := k) t).mul_mem_left g hf

lemma mul_mem_detIdeal_right {t : ℕ} (g : R m n k) {f : R m n k}
    (hf : f ∈ detIdeal (m := m) (n := n) (k := k) t) :
    f * g ∈ detIdeal (m := m) (n := n) (k := k) t := by
  simpa [mul_comm] using mul_mem_detIdeal_left (m := m) (n := n) (k := k) (t := t) g hf

end Helpers

end Determinantal
